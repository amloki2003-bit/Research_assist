#!/usr/bin/env sh
#-----------------------------------------------------------------------------
# Maven wrapper script generated to run Maven commands when Maven is not installed
#-----------------------------------------------------------------------------

PRG="$0"
while [ -h "$PRG" ] ; do
  ls=$(ls -ld "$PRG")
  link=$(expr "$ls" : '.*-> \(.*\)$')
  if expr "$link" : '/.*' > /dev/null; then
    PRG="$link"
  else
    PRG=$(dirname "$PRG")/"$link"
  fi
done

PRGDIR=$(dirname "$PRG")

exec "$PRGDIR/.mvn/wrapper/mvnw" "$@"
